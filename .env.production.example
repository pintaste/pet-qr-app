# Pet QR System - Production Environment Variables
# Copy this file to .env.production and fill in the values

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=pet_qr_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=your-redis-password-here

# ============================================
# Application Configuration
# ============================================
SECRET_KEY=your-very-long-secret-key-at-least-32-characters
ENVIRONMENT=production
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# Docker Images (from GitHub Container Registry)
# ============================================
# Replace 'your-username' with your GitHub username
BACKEND_IMAGE=ghcr.io/your-username/pet-qr-app/backend:main
FRONTEND_IMAGE=ghcr.io/your-username/pet-qr-app/frontend:main

# ============================================
# Port Configuration
# ============================================
FRONTEND_PORT=80

# ============================================
# Google Maps API (Optional)
# ============================================
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
