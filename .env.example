# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pet_qr_system
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=pet_qr_system
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# S3 Configuration
S3_BUCKET_NAME=pet-qr-uploads
S3_ENDPOINT_URL=  # Leave empty for AWS S3, set for LocalStack or custom S3

# CloudFront Configuration (optional)
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# SES Configuration
SES_FROM_EMAIL=noreply@yourdomain.com
SES_REGION=us-east-1

# Application Configuration
APP_NAME=Pet QR System
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# QR Code Configuration
QR_CODE_BASE_URL=https://yourdomain.com/qr
DEFAULT_QR_SIZE=200

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
SCAN_RATE_LIMIT_PER_HOUR=100

# Super Admin Configuration
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=change-this-super-secure-password

# Frontend Configuration (for Vite)
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Pet QR System
VITE_DEBUG=true

# Development Tools
ENABLE_DOCS=true
ENABLE_REDOC=true